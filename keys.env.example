NVIDIA_API_KEY=
TAVILY_API_KEY=

# Optional checkout and binary overrides. Leave blank for the sibling checkout
# layout documented in README.md.
HERMES_REPO=
HERMES_BIN=
PYTHON_BIN=
DOCKER_BIN=

# Direct provider keys. Leave blank when using NVIDIA Inference.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# NVIDIA Inference defaults. The same key/model can be used for the three
# request families when the model is enabled for your account.
NVIDIA_MODEL_ID=aws/anthropic/bedrock-claude-sonnet-4-6

# Hermes Anthropic Messages uses the Anthropic SDK. The SDK appends
# /v1/messages, so this base URL must not include /v1.
NVIDIA_MESSAGES_BASE_URL=https://inference-api.nvidia.com

# OpenAI-compatible lanes use the /v1 base.
NVIDIA_CHAT_BASE_URL=https://inference-api.nvidia.com/v1
NVIDIA_RESPONSES_BASE_URL=https://inference-api.nvidia.com/v1

# Provider-agnostic per-lane overrides. Leave these blank for the NVIDIA
# defaults above. Set them when using direct Anthropic or OpenAI keys.
# HERMES_DEMO_API_KEY_ENV can point every lane at the same key variable.
HERMES_DEMO_API_KEY_ENV=

# *_PROVIDER_LABEL only changes the display name in generated Hermes config.
MESSAGES_API_KEY_ENV=
MESSAGES_BASE_URL=
MESSAGES_MODEL_ID=
MESSAGES_PROVIDER_LABEL=

CHAT_API_KEY_ENV=
CHAT_BASE_URL=
CHAT_MODEL_ID=
CHAT_PROVIDER_LABEL=

RESPONSES_API_KEY_ENV=
RESPONSES_BASE_URL=
RESPONSES_MODEL_ID=
RESPONSES_PROVIDER_LABEL=

# NVIDIA-specific per-lane model overrides.
NVIDIA_MESSAGES_MODEL_ID=
NVIDIA_CHAT_MODEL_ID=
NVIDIA_RESPONSES_MODEL_ID=

# Phoenix overrides.
PHOENIX_UI_PORT=6006
PHOENIX_IMAGE=arizephoenix/phoenix:latest
PHOENIX_PROJECT_PREFIX=nemo-relay-hermes-demo
